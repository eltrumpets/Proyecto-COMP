Gramática

    0 $accept: program $end

    1 program: "void" "identifier" "(" ")" "{" body "}"

    2 body: body declaration
    3     | body statement
    4     | ε

    5 declaration: "var" tipo id_list ";"
    6            | "const" tipo id_list ";"

    7 tipo: "int"

    8 id_list: id_decl
    9        | id_list "," id_decl

   10 id_decl: "identifier"
   11        | "identifier" "=" expression

   12 statement: "identifier" "=" expression
   13          | "{" statement_list "}"
   14          | "if" "(" expression ")" statement "else" statement
   15          | "if" "(" expression ")" statement
   16          | "while" "(" expression ")" statement
   17          | "print" "(" print_list ")" ";"
   18          | "read" "(" read_list ")" ";"
   19          | error

   20 statement_list: statement_list statement
   21               | ε

   22 print_list: print_item
   23           | print_list "," print_item

   24 print_item: expression
   25           | "cadena"

   26 read_list: "identifier"
   27          | read_list "," "identifier"

   28 expression: expression "+" expression
   29           | expression "-" expression
   30           | expression "*" expression
   31           | expression "/" expression
   32           | "number"
   33           | "identifier"
   34           | "(" expression ")"
   35           | "-" expression
   36           | "(" error ")"


