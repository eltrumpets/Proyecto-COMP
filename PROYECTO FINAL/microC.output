Gramática

    0 $accept: program $end

    1 $@1: ε

    2 program: $@1 "void" "identifier" "(" ")" "{" body "}"

    3 body: body declaration
    4     | body statement
    5     | ε

    6 $@2: ε

    7 declaration: "var" $@2 tipo id_list ";"

    8 $@3: ε

    9 declaration: "const" $@3 tipo id_list ";"

   10 tipo: "int"

   11 id_list: id_decl
   12        | id_list "," id_decl

   13 id_decl: "identifier"
   14        | "identifier" "=" expression

   15 statement: "identifier" "=" expression ";"
   16          | "{" statement_list "}"
   17          | "if" "(" expression ")" statement "else" statement
   18          | "if" "(" expression ")" statement
   19          | "while" "(" expression ")" statement
   20          | "print" "(" print_list ")" ";"
   21          | "read" "(" read_list ")" ";"
   22          | error

   23 statement_list: statement_list statement
   24               | ε

   25 print_list: print_item
   26           | print_list "," print_item

   27 print_item: expression
   28           | "cadena"

   29 read_list: "identifier"
   30          | read_list "," "identifier"

   31 expression: expression "+" expression
   32           | expression "-" expression
   33           | expression "*" expression
   34           | expression "/" expression
   35           | "number"
   36           | "identifier"
   37           | "(" expression ")"
   38           | "-" expression
   39           | "(" error ")"


