Gramática

    0 $accept: program $end

    1 $@1: ε

    2 $@2: ε

    3 program: $@1 "void" "identifier" $@2 "(" ")" "{" body "}"

    4 body: body declaration
    5     | body statement
    6     | ε

    7 $@3: ε

    8 declaration: "var" $@3 tipo id_list ";"

    9 $@4: ε

   10 declaration: "const" $@4 tipo id_list ";"

   11 tipo: "int"

   12 id_list: id_decl
   13        | id_list "," id_decl

   14 id_decl: "identifier"
   15        | "identifier" "=" expression

   16 statement: "identifier" "=" expression ";"
   17          | "{" statement_list "}"
   18          | "if" "(" expression ")" statement "else" statement
   19          | "if" "(" expression ")" statement
   20          | "while" "(" expression ")" statement
   21          | "print" "(" print_list ")" ";"
   22          | "read" "(" read_list ")" ";"
   23          | "do" statement "while" "(" expression ")" ";"

   24 statement_list: statement_list statement
   25               | ε

   26 print_list: print_item
   27           | print_list "," print_item

   28 print_item: expression
   29           | "cadena"

   30 read_list: "identifier"
   31          | read_list "," "identifier"

   32 expression: expression "+" expression
   33           | expression "-" expression
   34           | expression "*" expression
   35           | expression "/" expression
   36           | "number"
   37           | "identifier"
   38           | "(" expression ")"
   39           | "-" expression
   40           | expression "<" expression
   41           | expression ">" expression
   42           | expression "<=" expression
   43           | expression ">=" expression
   44           | expression "==" expression
   45           | expression "!=" expression
   46           | "(" error ")"


