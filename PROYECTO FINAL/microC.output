    "*" (271) 34
    "void" (272) 3
    "var" (273) 8
    "const" (274) 10
    "int" (275) 11
    "if" (276) 18 19
    "else" (277) 18
    "while" (278) 20
    "read" (279) 22
    "/" (280) 35
    SIGNO (281)
    NOELSE (282)


